{
  "name": "seedr",
  "version": "1.0.0",
  "description": "BitTorrent ratio master - emulates BT clients and reports upload to private trackers",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "sh scripts/version.sh && tsc && cp src/version.json dist/version.json && cd ui && npm run build",
    "build:backend": "tsc",
    "build:ui": "cd ui && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bencode": "^4.0.0",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.1",
    "@fastify/static": "^8.1.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "randexp": "^0.5.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
